{
    "name": "expo1-reims26",
    "description": "EXPO1-REIMS26 pipeline (live, hourly): parse -> clean -> resample -> transform -> aggregate -> exportcsv",
    "dataset": "EXPO1-REIMS26",
    "steps": [
        {
            "treatment": "parse",
            "name": "parse",
            "input": "00_raw",
            "output": "10_parsed",
            "params": {
                "timestamp_column": "datetime",
                "domains": {
                    "bio_signal": {
                        "prefix": "i99",
                        "dtype": "int"
                    }
                }
            }
        },
        {
            "treatment": "clean",
            "name": "clean",
            "input": "10_parsed",
            "output": "20_clean"
        },
        {
            "treatment": "resample",
            "name": "resample",
            "input": "20_clean",
            "output": "25_resampled",
            "params": {
                "max_gap_fill_s": 20
            }
        },
        {
            "treatment": "transform",
            "name": "transform",
            "input": "25_resampled",
            "output": "30_transform"
        },
        {
            "treatment": "aggregate",
            "name": "aggregate",
            "input": "30_transform",
            "output": "40_aggregated",
            "params": {
                "windows": ["10s", "60s"]
            }
        },
        {
            "treatment": "exportcsv",
            "name": "exportcsv",
            "input": "40_aggregated",
            "output": "61_exportcsv",
            "params": {
                "aggregation": "10s",
                "domain": "bio_signal",
                "tz": "Europe/Paris",
                "columns": {
                    "i99001__raw__mean": "i99001",
                    "i99002__raw__mean": "i99002",
                    "i99003__raw__mean": "i99003",
                    "i99004__raw__mean": "i99004",
                    "i99005__raw__mean": "i99005",
                    "i99006__raw__mean": "i99006"
                }
            }
        }
    ]
}
