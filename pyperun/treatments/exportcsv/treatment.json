{
    "name": "exportcsv",
    "description": "Export aggregated parquet data to a single CSV file with column selection, renaming, timezone conversion, and optional rounding",
    "input_format": "Parquet files: `<source>__<domain>__<YYYY-MM-DD>__<window>.parquet`",
    "output_format": "One CSV file per source device: `<source>.csv`",
    "params": {
        "aggregation": {
            "type": "str",
            "default": "10s",
            "description": "Aggregation window to select for export (must match a window produced by aggregate)"
        },
        "domain": {
            "type": "str",
            "default": "bio_signal",
            "description": "Domain to export (bio_signal or environment)"
        },
        "tz": {
            "type": "str",
            "default": "Europe/Paris",
            "description": "Timezone for timestamp conversion in the output CSV (IANA format)"
        },
        "columns": {
            "type": "dict",
            "default": {
                "m0__raw__mean": {"name": "c0", "dtype": "int"},
                "m1__raw__mean": {"name": "c1", "dtype": "int"},
                "m2__raw__mean": {"name": "c2", "dtype": "int"},
                "m3__raw__mean": {"name": "c3", "dtype": "int"},
                "m4__raw__mean": {"name": "c4", "dtype": "int"},
                "m5__raw__mean": {"name": "c5", "dtype": "int"},
                "m6__raw__mean": {"name": "c6", "dtype": "int"},
                "m7__raw__mean": {"name": "c7", "dtype": "int"},
                "m8__raw__mean": {"name": "c8", "dtype": "int"},
                "m9__raw__mean": {"name": "c9", "dtype": "int"},
                "m10__raw__mean": {"name": "c10", "dtype": "int"},
                "m11__raw__mean": {"name": "c11", "dtype": "int"}
            },
            "description": "Column selection and renaming: map source column name to output spec (name = export column name, dtype = int/float/str for casting)"
        }
    }
}
